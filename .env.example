DASS_ENVIRONMENT=local
DASS_LOG_LEVEL=INFO
DASS_DATABASE_URL=postgresql+psycopg://dass:dass@postgres:5432/dass
DASS_DATABASE_ECHO=false
DASS_QUEUE_BACKEND=sqs
DASS_QUEUE_NAME=dass-tasks
DASS_QUEUE_NAME_NORMAL=dass-tasks-normal
DASS_QUEUE_NAME_RETRY=dass-tasks-retry
DASS_AWS_REGION=us-east-1
DASS_AWS_ACCESS_KEY_ID=dass
DASS_AWS_SECRET_ACCESS_KEY=dass
DASS_SQS_ENDPOINT_URL=http://localstack:4566
DASS_SCHEDULER_INTERVAL_SECONDS=5
DASS_SCHEDULER_LOCKED_TASK_SCAN_SECONDS=5
DASS_WORKER_VISIBILITY_TIMEOUT_SECONDS=300
DASS_WORKER_ID=worker-1
DASS_HTTP_REQUEST_TIMEOUT_SECONDS=30
DASS_SHELL_EXECUTION_ENABLED=true
DASS_BACKEND_URL=http://api-server:8000
DASS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
